      "clientId": "${QCLAW_DINGTALK_CLIENT_ID}",
      "clientSecret": "${QCLAW_DINGTALK_CLIENT_SECRET}",
      "gatewayToken": "019f03336c59e87c3e7c3b0bcd410fd4baf17941a48fa92f"

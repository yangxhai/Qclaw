{
  "meta": {
    "lastTouchedVersion": "2026.3.13",
    "lastTouchedAt": "2026-03-24T00:39:47.577Z"
  },
  "browser": {
    "enabled": true,
    "defaultProfile": "openclaw",
    "ssrfPolicy": {
      "dangerouslyAllowPrivateNetwork": false
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "qclaw": {
        "baseUrl": "${QCLAW_LLM_BASE_URL}",
        "apiKey": "${QCLAW_LLM_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "modelroute",
            "name": "modelroute"
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "qclaw/modelroute"
      },
      "workspace": "/Users/yanghh/.qclaw/workspace",
      "compaction": {
        "mode": "safeguard"
      },
      "timeoutSeconds": 72000,
      "maxConcurrent": 3
    }
  },
  "tools": {
    "alsoAllow": [
      "skillhub_install"
    ],
    "web": {
      "search": {
        "enabled": true
      }
    }
  },
  "messages": {
    "queue": {
      "mode": "followup"
